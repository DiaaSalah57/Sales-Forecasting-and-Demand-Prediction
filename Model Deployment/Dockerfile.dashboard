# Dockerfile for the Streamlit dashboard
FROM python:3.11-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY 3_dashboard.py .

EXPOSE 8501

RUN mkdir -p ~/.streamlit && echo '[server]\naddress = 0.0.0.0\nport = 8501' > ~/.streamlit/config.toml

CMD ["streamlit", "run", "3_dashboard.py"]
